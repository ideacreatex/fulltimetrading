# Alpaca Market Data API.
# Used only for https://data.alpaca.markets historical/market data requests.
APCA_DATA_API_KEY_ID=your_alpaca_data_key_id
APCA_DATA_API_SECRET_KEY=your_alpaca_data_secret_key

# Legacy fallback for market data. Prefer APCA_DATA_* above.
# APCA_API_KEY_ID=your_alpaca_key_id
# APCA_API_SECRET_KEY=your_alpaca_secret_key

# Alpaca Paper Trading API.
# Used by guarded paper-plan/paper-monitor/paper-cycle commands.
# Orders are still blocked unless config/config.php has trading.alpaca.orders_enabled=true.
APCA_PAPER_API_KEY_ID=your_alpaca_paper_key_id
APCA_PAPER_API_SECRET_KEY=your_alpaca_paper_secret_key
APCA_PAPER_BASE_URL=https://paper-api.alpaca.markets/v2
# Optional safety check. Accepts Alpaca account id or visible paper account number, e.g. PA3BEBVCD1SY.
APCA_PAPER_ACCOUNT_ID=your_expected_paper_account_id_or_account_number
APCA_PAPER_ACCOUNT_LABEL=paper_strategy_test
# Use 2 for ordinary margin paper tests. Use 4 only after enabling 4x in Alpaca and testing intraday risk separately.
APCA_PAPER_EXPECTED_MULTIPLIER=2
APCA_PAPER_EXPECTED_SHORTING_ENABLED=true

# Telegram notifications for daily dry-run/status reports.
# Create a bot via @BotFather, add it to your channel/group, and put the channel id or @channel username here.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_or_channel_id

# Safety note:
# This project only calls https://data.alpaca.markets for historical market data.
# Do not put live trading credentials here. Paper trading keys are separate from
# data keys so code cannot accidentally mix data access and order placement.
