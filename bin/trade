/**
 * @return array{command:string, options:array<string, string|bool>}
 */
function parse_cli(array $argv): array
{
    $command = $argv[1] ?? 'help';
    $options = [];
    foreach (array_slice($argv, 2) as $arg) {
        if (!str_starts_with($arg, '--')) {
            continue;
        }
        $arg = substr($arg, 2);
        if (str_contains($arg, '=')) {
            [$key, $value] = explode('=', $arg, 2);
            $options[$key] = $value;
        } else {
            $options[$arg] = true;
        }
    }

    return ['command' => $command, 'options' => $options];
}

/** @return list<string> */
function symbols_from_option(array $options, string $key, array $default = []): array
{
    $fileKey = $key . '-file';
    if (isset($options[$fileKey])) {
        $symbols = symbols_from_file((string) $options[$fileKey]);
        if ($symbols === []) {
            throw new RuntimeException('No symbols found in --' . $fileKey);
        }

        return $symbols;
    }

    $raw = (string) ($options[$key] ?? implode(',', $default));
    $symbols = array_values(array_filter(array_map(
        static fn (string $s): string => strtoupper(trim($s)),
        explode(',', $raw),
    )));
    if ($symbols === []) {
        throw new RuntimeException('Missing --' . $key);
    }

    return $symbols;
}

/** @return list<string> */
function optional_symbols_from_option(array $options, string $key): array
{
    if (!isset($options[$key]) && !isset($options[$key . '-file'])) {
        return [];
    }

    return symbols_from_option($options, $key, []);
}

/** @return list<string> */
function symbols_from_file(string $file): array
{
    if (!is_file($file)) {
        throw new RuntimeException('Symbols file not found: ' . $file);
    }

    $ext = strtolower(pathinfo($file, PATHINFO_EXTENSION));
    if ($ext === 'json') {
        $payload = json_decode((string) file_get_contents($file), true, 512, JSON_THROW_ON_ERROR);
        $items = $payload['symbols'] ?? $payload['universe'] ?? $payload;
        if (!is_array($items)) {
            return [];
        }

        $symbols = [];
        foreach ($items as $item) {
            if (is_string($item)) {
                $symbols[] = $item;
                continue;
            }
            if (is_array($item) && isset($item['symbol'])) {
                $symbols[] = (string) $item['symbol'];
            }
        }

        return clean_symbols($symbols);
    }

    $content = (string) file_get_contents($file);
    $symbols = preg_split('/[\s,;]+/', $content) ?: [];

    return clean_symbols($symbols);
}

/** @param list<string> $symbols @return list<string> */
function clean_symbols(array $symbols): array
{
    $clean = [];
    foreach ($symbols as $symbol) {
        $symbol = strtoupper(trim($symbol));
        if ($symbol === '' || !preg_match('/^[A-Z][A-Z0-9.\-^=]{0,12}$/', $symbol)) {
            continue;
        }
        $clean[$symbol] = true;
    }

    return array_keys($clean);
}

/** @return list<array{captured_at:string, session_type:string, code:string, value:?float, payload:array<string, mixed>}> */
function dashboard_metrics_from_csv(string $file, string $sessionType): array
{
    if (!is_file($file)) {
        throw new RuntimeException('Dashboard CSV not found: ' . $file);
    }

    $handle = fopen($file, 'rb');
    if ($handle === false) {
        throw new RuntimeException('Unable to read dashboard CSV: ' . $file);
    }

    $header = fgetcsv($handle);
    if ($header === false) {
        fclose($handle);
        return [];
    }
    $header = array_map(static fn (string $value): string => strtolower(trim($value)), $header);

    $metrics = [];
    while (($values = fgetcsv($handle)) !== false) {
        if (count($values) !== count($header)) {
            continue;
        }

        $row = array_combine($header, $values);
        if ($row === false) {
            continue;
        }

        $code = strtoupper(trim((string) ($row['code'] ?? $row['symbol'] ?? '')));
        if ($code === '') {
            continue;
        }

        $valueRaw = trim((string) ($row['value'] ?? ''));
        $metrics[] = [
            'captured_at' => (string) ($row['captured_at'] ?? $row['time'] ?? (new DateTimeImmutable())->format(DateTimeInterface::ATOM)),
            'session_type' => (string) ($row['session_type'] ?? $sessionType),
            'code' => $code,
            'value' => $valueRaw === '' ? null : (float) $valueRaw,
            'payload' => $row,
        ];
    }
    fclose($handle);

    return $metrics;
}

/** @return list<array{captured_at:string, symbol:string, timeframe:string, indicator:string, signal:?string, value:?float, payload:array<string, mixed>}> */
function external_indicator_snapshots_from_csv(string $file): array
{
    if (!is_file($file)) {
        throw new RuntimeException('Indicator CSV not found: ' . $file);
    }

    $handle = fopen($file, 'rb');
    if ($handle === false) {
        throw new RuntimeException('Unable to read indicator CSV: ' . $file);
    }

    $header = fgetcsv($handle);
    if ($header === false) {
        fclose($handle);
        return [];
    }
    $header = array_map(static fn (string $value): string => strtolower(trim($value)), $header);

    $snapshots = [];
    while (($values = fgetcsv($handle)) !== false) {
        if (count($values) !== count($header)) {
            continue;
        }

        $row = array_combine($header, $values);
        if ($row === false) {
            continue;
        }

        $symbol = strtoupper(trim((string) ($row['symbol'] ?? '')));
        $indicator = strtolower(trim((string) ($row['indicator'] ?? '')));
        if ($symbol === '' || $indicator === '') {
            continue;
        }

        $valueRaw = trim((string) ($row['value'] ?? ''));
        $signal = trim((string) ($row['signal'] ?? ''));
        $snapshots[] = [
            'captured_at' => (string) ($row['captured_at'] ?? $row['time'] ?? $row['date'] ?? (new DateTimeImmutable())->format(DateTimeInterface::ATOM)),
            'symbol' => $symbol,
            'timeframe' => (string) ($row['timeframe'] ?? '1D'),
            'indicator' => $indicator,
            'signal' => $signal === '' ? null : $signal,
            'value' => $valueRaw === '' ? null : (float) $valueRaw,
            'payload' => $row,
        ];
    }
    fclose($handle);

    return $snapshots;
}

/**
 * @return array{
 *   dashboard:list<array{captured_at:string, session_type:string, code:string, value:?float, payload:array<string, mixed>}>,
 *   indicators:list<array{captured_at:string, symbol:string, timeframe:string, indicator:string, signal:?string, value:?float, payload:array<string, mixed>}>
 * }
 */
function historical_export_from_csv(string $file, string $source, string $sessionType): array
{
    if (!is_file($file)) {
        throw new RuntimeException('Historical export CSV not found: ' . $file);
    }

    $handle = fopen($file, 'rb');
    if ($handle === false) {
        throw new RuntimeException('Unable to read historical export CSV: ' . $file);
    }

    $header = fgetcsv($handle);
    if ($header === false) {
        fclose($handle);
        return ['dashboard' => [], 'indicators' => []];
    }
    $header = array_map(static fn (string $value): string => strtolower(trim($value)), $header);

    $dashboard = [];
    $indicators = [];
    while (($values = fgetcsv($handle)) !== false) {
        if (count($values) !== count($header)) {
            continue;
        }
        $row = array_combine($header, $values);
        if ($row === false) {
            continue;
        }

        $capturedAt = (string) ($row['captured_at'] ?? $row['time'] ?? $row['date'] ?? $row['datetime'] ?? '');
        if ($capturedAt === '') {
            continue;
        }

        if (isset($row['code']) && isset($row['value'])) {
            $dashboard[] = [
                'captured_at' => $capturedAt,
                'session_type' => (string) ($row['session_type'] ?? $sessionType),
                'code' => strtoupper(trim((string) $row['code'])),
                'value' => trim((string) $row['value']) === '' ? null : (float) $row['value'],
                'payload' => array_merge($row, ['source' => $source]),
            ];
            continue;
        }

        if (isset($row['symbol'], $row['indicator'])) {
            $valueRaw = trim((string) ($row['value'] ?? ''));
            $signal = trim((string) ($row['signal'] ?? ''));
            $indicators[] = [
                'captured_at' => $capturedAt,
                'symbol' => strtoupper(trim((string) $row['symbol'])),
                'timeframe' => (string) ($row['timeframe'] ?? '1D'),
                'indicator' => strtolower(trim((string) $row['indicator'])),
                'signal' => $signal === '' ? null : $signal,
                'value' => $valueRaw === '' ? null : (float) $valueRaw,
                'payload' => array_merge($row, ['source' => $source]),
            ];
            continue;
        }

        $symbol = strtoupper(trim((string) ($row['symbol'] ?? 'MARKET')));
        $timeframe = (string) ($row['timeframe'] ?? '1D');
        foreach ($row as $column => $value) {
            if (in_array($column, ['captured_at', 'time', 'date', 'datetime', 'session_type', 'symbol', 'timeframe'], true)) {
                continue;
            }
            $value = trim((string) $value);
            if ($value === '') {
                continue;
            }

            if (preg_match('/^(s5|nd|di)[a-z0-9_]*$/i', $column)) {
                $dashboard[] = [
                    'captured_at' => $capturedAt,
                    'session_type' => (string) ($row['session_type'] ?? $sessionType),
                    'code' => strtoupper($column),
                    'value' => is_numeric($value) ? (float) $value : null,
                    'payload' => array_merge($row, ['source' => $source, 'column' => $column, 'raw_value' => $value]),
                ];
            } else {
                $indicators[] = [
                    'captured_at' => $capturedAt,
                    'symbol' => $symbol,
                    'timeframe' => $timeframe,
                    'indicator' => strtolower($column),
                    'signal' => is_numeric($value) ? null : $value,
                    'value' => is_numeric($value) ? (float) $value : null,
                    'payload' => array_merge($row, ['source' => $source, 'column' => $column, 'raw_value' => $value]),
                ];
            }
        }
    }
    fclose($handle);

    return ['dashboard' => $dashboard, 'indicators' => $indicators];
}

function provider_from_options(Config $config, array $options, SqliteRepository $repo): MarketDataProvider
{
    $provider = (string) ($options['provider'] ?? 'alpaca');
    $http = new HttpClient();

    return match ($provider) {
        'alpaca' => new CachedMarketDataProvider(
            new AlpacaBarsProvider(
                $http,
                (string) $config->get('data.alpaca.base_url'),
                (string) ($options['feed'] ?? $config->get('data.alpaca.feed', 'iex')),
                (string) ($options['adjustment'] ?? $config->get('data.alpaca.adjustment', 'split')),
                (int) $config->get('data.alpaca.limit', 10000),
            ),
            (string) $config->get('cache_path'),
            'alpaca',
        ),
        'stooq' => new CachedMarketDataProvider(
            new StooqBarsProvider($http, (string) $config->get('data.stooq.base_url')),
            (string) $config->get('cache_path'),
            'stooq',
        ),
        'yahoo' => new CachedMarketDataProvider(
            new YahooChartProvider($http),
            (string) $config->get('cache_path'),
            'yahoo',
        ),
        'db' => new class ($repo) implements MarketDataProvider {
            public function __construct(private readonly SqliteRepository $repo)
            {
            }

            public function getBars(array $symbols, string $timeframe, string $start, string $end): array
            {
                return $this->repo->loadBars($symbols, $timeframe, $start, $end);
            }
        },
        default => throw new RuntimeException('Unknown provider: ' . $provider),
    };
}

/** @return array<string, mixed> */
function strategy_config_from_options(Config $config, array $options): array
{
    $strategy = $config->get('strategy', []);
    if (!is_array($strategy)) {
        $strategy = [];
    }

    $support = $strategy['support_regularity'] ?? [];
    if (!is_array($support)) {
        $support = [];
    }
    $short = $strategy['short_resistance'] ?? [];
    if (!is_array($short)) {
        $short = [];
    }

    $mapping = [
        'support-min-touches' => ['min_touches', 'int'],
        'support-min-success-rate' => ['min_success_rate', 'float'],
        'support-success-min-return-pct' => ['success_min_return_pct', 'float'],
        'support-lookback-bars' => ['lookback_bars', 'int'],
        'support-forward-bars' => ['forward_bars', 'int'],
        'support-near-pct' => ['near_pct', 'float'],
        'support-near-atr-multiple' => ['near_atr_multiple', 'float'],
        'support-touch-tolerance-pct' => ['touch_tolerance_pct', 'float'],
        'support-violation-tolerance-pct' => ['violation_tolerance_pct', 'float'],
        'support-stop-atr-multiple' => ['stop_atr_multiple', 'float'],
        'support-target-atr-multiple' => ['target_atr_multiple', 'float'],
        'support-cooldown-bars' => ['cooldown_bars', 'int'],
    ];

    foreach ($mapping as $option => [$key, $type]) {
        if (!isset($options[$option])) {
            continue;
        }
        $support[$key] = $type === 'int' ? (int) $options[$option] : (float) $options[$option];
    }

    if (isset($options['support-require-close-above'])) {
        $support['require_close_above_support'] = bool_option($options['support-require-close-above']);
    }

    if (isset($options['support-enabled'])) {
        $support['enabled'] = bool_option($options['support-enabled']);
    }
    if (isset($options['support-weekly-enabled'])) {
        $support['weekly_enabled'] = bool_option($options['support-weekly-enabled']);
    }

    $shortMapping = [
        'short-min-touches' => ['min_touches', 'int'],
        'short-min-success-rate' => ['min_success_rate', 'float'],
        'short-success-min-return-pct' => ['success_min_return_pct', 'float'],
        'short-lookback-bars' => ['lookback_bars', 'int'],
        'short-forward-bars' => ['forward_bars', 'int'],
        'short-near-pct' => ['near_pct', 'float'],
        'short-near-atr-multiple' => ['near_atr_multiple', 'float'],
        'short-touch-tolerance-pct' => ['touch_tolerance_pct', 'float'],
        'short-violation-tolerance-pct' => ['violation_tolerance_pct', 'float'],
        'short-stop-atr-multiple' => ['stop_atr_multiple', 'float'],
        'short-target-atr-multiple' => ['target_atr_multiple', 'float'],
        'short-cooldown-bars' => ['cooldown_bars', 'int'],
        'short-max-market-score' => ['max_market_score', 'float'],
    ];

    foreach ($shortMapping as $option => [$key, $type]) {
        if (!isset($options[$option])) {
            continue;
        }
        $short[$key] = $type === 'int' ? (int) $options[$option] : (float) $options[$option];
    }

    if (isset($options['short-require-close-below'])) {
        $short['require_close_below_resistance'] = bool_option($options['short-require-close-below']);
    }

    $shortSymbols = optional_symbols_from_option($options, 'short-symbols');
    if ($shortSymbols !== []) {
        $strategy['short_symbols'] = $shortSymbols;
        $short['enabled'] = true;
    }
    if (isset($options['short-enabled'])) {
        $short['enabled'] = bool_option($options['short-enabled']);
    }

    $inverseSymbols = optional_symbols_from_option($options, 'inverse-symbols');
    if ($inverseSymbols !== []) {
        $strategy['inverse_long_symbols'] = $inverseSymbols;
    }
    if (isset($options['inverse-max-market-score'])) {
        $inverse = $strategy['inverse_long'] ?? [];
        if (!is_array($inverse)) {
            $inverse = [];
        }
        $inverse['max_market_score'] = (float) $options['inverse-max-market-score'];
        $strategy['inverse_long'] = $inverse;
    }

    $marketDip = $strategy['market_dip_entry'] ?? [];
    if (!is_array($marketDip)) {
        $marketDip = [];
    }
    $marketDipMapping = [
        'market-dip-min-drawdown-pct' => ['min_spy_drawdown_pct', 'float'],
        'market-dip-max-drawdown-pct' => ['max_spy_drawdown_pct', 'float'],
        'market-dip-max-market-score' => ['max_market_score', 'float'],
        'market-dip-max-spy-rsi14' => ['max_spy_rsi14', 'float'],
    ];
    foreach ($marketDipMapping as $option => [$key, $type]) {
        if (isset($options[$option])) {
            $marketDip[$key] = (float) $options[$option];
        }
    }
    if (isset($options['market-dip-enabled'])) {
        $marketDip['enabled'] = bool_option($options['market-dip-enabled']);
    }
    if (isset($options['market-dip-only'])) {
        $marketDip['only'] = bool_option($options['market-dip-only']);
    }
    $strategy['market_dip_entry'] = $marketDip;

    if (isset($options['order-fill-mode'])) {
        $mode = (string) $options['order-fill-mode'];
        if (!in_array($mode, ['next_touch', 'same_day_touch'], true)) {
            throw new RuntimeException('--order-fill-mode must be next_touch or same_day_touch');
        }
        $strategy['order_fill_mode'] = $mode;
    }

    $clubRules = $strategy['club_rules'] ?? [];
    if (!is_array($clubRules)) {
        $clubRules = [];
    }
    $clubMapping = [
        'stable-position-pct' => 'stable_market_position_pct',
        'unstable-position-pct' => 'unstable_market_position_pct',
        'max-gross-exposure-pct' => 'max_gross_exposure_pct',
    ];
    foreach ($clubMapping as $option => $key) {
        if (isset($options[$option])) {
            $clubRules[$key] = (float) $options[$option];
        }
    }
    $strategy['club_rules'] = $clubRules;

    $layered = $strategy['layered_positions'] ?? [];
    if (!is_array($layered)) {
        $layered = [];
    }
    if (isset($options['layered-positions-enabled'])) {
        $layered['enabled'] = bool_option($options['layered-positions-enabled']);
    }
    if (isset($options['require-green-garden'])) {
        $layered['require_green_garden'] = bool_option($options['require-green-garden']);
    }
    if (isset($options['same-symbol-max-layers'])) {
        $layered['same_symbol_max_layers'] = (int) $options['same-symbol-max-layers'];
    }
    if (isset($options['green-garden-profit-pct'])) {
        $layered['green_garden_profit_pct'] = (float) $options['green-garden-profit-pct'];
    }
    $strategy['layered_positions'] = $layered;

    $externalFilters = $strategy['external_filters'] ?? [];
    if (!is_array($externalFilters)) {
        $externalFilters = [];
    }
    if (isset($options['external-filters-enabled'])) {
        $externalFilters['enabled'] = bool_option($options['external-filters-enabled']);
    }
    if (isset($options['require-external-indicators'])) {
        $externalFilters['require_history'] = bool_option($options['require-external-indicators']);
    }
    $strategy['external_filters'] = $externalFilters;

    $market = $strategy['market'] ?? [];
    if (is_array($market) && isset($options['market-require-spy-above-ema20'])) {
        $market['require_spy_above_ema20'] = bool_option($options['market-require-spy-above-ema20']);
        $strategy['market'] = $market;
    }

    $strategy['support_regularity'] = $support;
    $strategy['short_resistance'] = $short;

    return $strategy;
}

/** @return array<string, mixed> */
function risk_config_from_options(Config $config, array $options): array
{
    $risk = $config->get('risk', []);
    if (!is_array($risk)) {
        $risk = [];
    }

    $mapping = [
        'initial-cash' => ['initial_cash', 'float'],
        'fixed-position-usd' => ['fixed_position_usd', 'float'],
        'risk-per-trade-pct' => ['risk_per_trade_pct', 'float'],
        'max-position-pct' => ['max_position_pct', 'float'],
        'max-open-positions' => ['max_open_positions', 'int'],
    ];
    foreach ($mapping as $option => [$key, $type]) {
        if (!isset($options[$option])) {
            continue;
        }
        $risk[$key] = $type === 'int' ? (int) $options[$option] : (float) $options[$option];
    }
    if (isset($options['allow-fractional-shares'])) {
        $risk['allow_fractional_shares'] = bool_option($options['allow-fractional-shares']);
    }
    if (isset($options['position-sizing-mode'])) {
        $mode = (string) $options['position-sizing-mode'];
        if (!in_array($mode, ['capital_pct', 'risk'], true)) {
            throw new RuntimeException('--position-sizing-mode must be capital_pct or risk');
        }
        $risk['position_sizing_mode'] = $mode;
    }

    return $risk;
}

function bool_option(string|bool $value): bool
{
    if (is_bool($value)) {
        return $value;
    }

    return in_array(strtolower($value), ['1', 'true', 'yes', 'y', 'on'], true);
}

/** @param array<string, mixed> $account @return array<string, mixed> */
function alpaca_account_summary(array $account): array
{
    $id = (string) ($account['id'] ?? '');
    $accountNumber = (string) ($account['account_number'] ?? '');

    return [
        'id_last4' => last4($id),
        'account_number_last4' => last4($accountNumber),
        'status' => $account['status'] ?? null,
        'currency' => $account['currency'] ?? null,
        'cash' => $account['cash'] ?? null,
        'equity' => $account['equity'] ?? $account['portfolio_value'] ?? null,
        'buying_power' => $account['buying_power'] ?? null,
        'multiplier' => $account['multiplier'] ?? null,
        'pattern_day_trader' => $account['pattern_day_trader'] ?? null,
        'daytrade_count' => $account['daytrade_count'] ?? null,
        'trading_blocked' => $account['trading_blocked'] ?? null,
        'transfers_blocked' => $account['transfers_blocked'] ?? null,
        'account_blocked' => $account['account_blocked'] ?? null,
        'shorting_enabled' => $account['shorting_enabled'] ?? null,
    ];
}

/** @param array<string, mixed> $account */
function alpaca_account_reference_matches(string $expected, array $account): bool
{
    $expected = trim($expected);
    if ($expected === '') {
        return true;
    }

    foreach (['id', 'account_number'] as $field) {
        $actual = trim((string) ($account[$field] ?? ''));
        if ($actual !== '' && hash_equals($expected, $actual)) {
            return true;
        }
    }

    return false;
}

function last4(string $value): ?string
{
    if ($value === '') {
        return null;
    }

    return substr($value, -4);
}

function print_help(): void
{
    echo <<<'TXT'
Usage:
  php bin/trade init-db [--db=var/db/trading.sqlite]
  php bin/trade fetch --provider=alpaca|yahoo|stooq --symbols=SPY,QQQ,SMH,AAPL --start=2021-01-01 --end=2025-12-31 [--feed=iex]
  php bin/trade scan --provider=alpaca|yahoo|stooq|db --symbols=AAPL,MSFT,NVDA --start=2021-01-01 --end=2025-12-31
  php bin/trade backtest --provider=alpaca|yahoo|stooq|db [--symbols=AAPL,MSFT,NVDA] --start=2021-01-01 --end=2025-12-31 [--benchmark=SPY] [--exclude-symbols=SQQQ,SCO] [--short-symbols-file=stocks.txt] [--inverse-symbols-file=inverse.txt]
  php bin/trade alpaca-account
  php bin/trade paper-cycle [--profile=tuned-daily|best-consistent|leverage-growth|default] [--submit=false] [--telegram=true] [--refresh-report=true]
  php bin/trade paper-daemon [--submit=false] [--monitor-interval-seconds=60]
  php bin/trade paper-plan [--report=var/reports/daily/alpaca_selected_best_partial_live_signal_report.json] [--submit=false] [--telegram=false]
  php bin/trade paper-monitor [--report=var/reports/daily/alpaca_selected_best_partial_live_signal_report.json] [--submit=false] [--telegram=true]
  php bin/trade paper-status [--limit=20]
  php bin/trade import-dashboard --file=dashboard.csv [--session=regular]
  php bin/trade import-indicators --file=indicators.csv
  php bin/trade import-history --file=history.csv [--source=fstock|tradingview] [--session=regular]

Support regularity tuning:
  Add --support-min-touches=4 --support-min-success-rate=0.70 --support-require-close-above=true to scan/backtest.
  Add --short-symbols-file=var/reports/universe_symbols.txt to enable short resistance signals for those symbols.
  Add --inverse-symbols-file=var/reports/universe_inverse_hedge_symbols.txt to allow inverse ETF long signals only in weak market regimes.
  Add --market-dip-enabled=true --market-dip-min-drawdown-pct=0.08 to allow support entries during strong SPY drawdowns.
  Add --market-dip-only=true to disable ordinary long entries outside the drawdown window.
  Add --support-weekly-enabled=true --order-fill-mode=same_day_touch to include weekly EMA/SMA touches and fill author-style touch entries.
  Add --layered-positions-enabled=true --same-symbol-max-layers=3 --require-green-garden=true for add-on layers after breakeven/green garden.
  Add --max-open-positions=3 --max-gross-exposure-pct=2 --unstable-position-pct=0.5 to test loading rules.
  Add --require-external-indicators=true only after importing historical FBMA/fstock/seasonality snapshots.
  Default sizing uses capital percentages from club rules. Use --position-sizing-mode=risk only for risk-budget sizing.

Alpaca:
  Copy .env.example to .env and set APCA_DATA_API_KEY_ID / APCA_DATA_API_SECRET_KEY for historical data.
  Set APCA_PAPER_API_KEY_ID / APCA_PAPER_API_SECRET_KEY only for future paper trading commands.
  Default feed is iex. Use --feed=sip only if your Alpaca subscription allows it.

TXT;
}

$parsed = parse_cli($argv);
$command = $parsed['command'];
$options = $parsed['options'];
$config = Config::fromFile(__DIR__ . '/../config/config.php');
$dbPath = (string) ($options['db'] ?? $config->get('database_path'));
$repo = new SqliteRepository($dbPath);

try {
    if ($command === 'help' || $command === '--help' || $command === '-h') {
        print_help();
        exit(0);
    }

    if ($command === 'init-db') {
        $repo->migrate();
        echo "Database ready: {$dbPath}\n";
        exit(0);
    }

    if ($command === 'alpaca-account') {
        $paperBaseUrl = getenv('APCA_PAPER_BASE_URL')
            ?: (string) $config->get('trading.alpaca.paper_base_url', 'https://paper-api.alpaca.markets/v2');
        $client = new AlpacaPaperClient(new HttpClient(), $paperBaseUrl);
        $account = $client->account();
        $expectedAccountRef = getenv('APCA_PAPER_ACCOUNT_ID') ?: '';
        if (!alpaca_account_reference_matches($expectedAccountRef, $account)) {
            throw new RuntimeException(
                'Alpaca paper account mismatch. Expected account ref last4=' . last4(trim($expectedAccountRef))
                . ', actual id last4=' . last4((string) ($account['id'] ?? ''))
                . ', actual account_number last4=' . last4((string) ($account['account_number'] ?? ''))
            );
        }
        $expectedMultiplier = trim((string) (getenv('APCA_PAPER_EXPECTED_MULTIPLIER') ?: ''));
        $actualMultiplier = trim((string) ($account['multiplier'] ?? ''));
        if ($expectedMultiplier !== '' && $actualMultiplier !== '' && !hash_equals($expectedMultiplier, $actualMultiplier)) {
            throw new RuntimeException('Alpaca paper multiplier mismatch. Expected ' . $expectedMultiplier . 'x, actual ' . $actualMultiplier . 'x.');
        }
        $expectedShortingRaw = getenv('APCA_PAPER_EXPECTED_SHORTING_ENABLED');
        $expectedShorting = is_string($expectedShortingRaw) && trim($expectedShortingRaw) !== ''
            ? bool_option($expectedShortingRaw)
            : null;
        $actualShorting = (bool) ($account['shorting_enabled'] ?? false);
        if ($expectedShorting !== null && $expectedShorting !== $actualShorting) {
            throw new RuntimeException('Alpaca paper shorting mismatch. Expected ' . ($expectedShorting ? 'enabled' : 'disabled') . ', actual ' . ($actualShorting ? 'enabled' : 'disabled') . '.');
        }

        echo json_encode([
            'paper_base_url' => $paperBaseUrl,
            'account_reference_match' => trim($expectedAccountRef) === '' ? null : true,
            'expected_multiplier_match' => $expectedMultiplier === '' ? null : true,
            'expected_shorting_match' => $expectedShorting === null ? null : true,
            'account' => alpaca_account_summary($account),
            'orders_enabled' => (bool) $config->get('trading.alpaca.orders_enabled', false),
            'paper_only' => (bool) $config->get('trading.alpaca.paper_only', true),
        ], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
        exit(0);
    }

    if ($command === 'paper-monitor') {
        require __DIR__ . '/../tools/paper_position_monitor.php';
        exit(0);
    }

    if ($command === 'paper-cycle') {
        require __DIR__ . '/../tools/paper_daily_cycle.php';
        exit(0);
    }

    if ($command === 'paper-daemon') {
        require __DIR__ . '/../tools/paper_daemon.php';
        exit(0);
    }

    if ($command === 'paper-plan') {
        require __DIR__ . '/../tools/paper_order_plan.php';
        exit(0);
    }

    if ($command === 'paper-status') {
        require __DIR__ . '/../tools/paper_status.php';
        exit(0);
    }

    $repo->migrate();
    $start = (string) ($options['start'] ?? '2020-01-01');
    $end = (string) ($options['end'] ?? (new DateTimeImmutable('today'))->format('Y-m-d'));
    $timeframe = (string) ($options['timeframe'] ?? '1Day');
    if ($command === 'import-dashboard') {
        $metrics = dashboard_metrics_from_csv(
            (string) ($options['file'] ?? ''),
            (string) ($options['session'] ?? 'regular'),
        );
        $repo->saveDashboardMetrics($metrics);
        echo 'Dashboard metrics imported: ' . count($metrics) . "\n";
        exit(0);
    }

    if ($command === 'import-indicators') {
        $snapshots = external_indicator_snapshots_from_csv((string) ($options['file'] ?? ''));
        $repo->saveExternalIndicatorSnapshots($snapshots);
        echo 'External indicator snapshots imported: ' . count($snapshots) . "\n";
        exit(0);
    }

    if ($command === 'import-history') {
        $history = historical_export_from_csv(
            (string) ($options['file'] ?? ''),
            (string) ($options['source'] ?? 'manual'),
            (string) ($options['session'] ?? 'regular'),
        );
        $repo->saveDashboardMetrics($history['dashboard']);
        $repo->saveExternalIndicatorSnapshots($history['indicators']);
        echo 'Historical dashboard metrics imported: ' . count($history['dashboard']) . "\n";
        echo 'Historical indicator snapshots imported: ' . count($history['indicators']) . "\n";
        exit(0);
    }

    $symbols = symbols_from_option($options, 'symbols', $config->get('watchlists.us_stocks', []));
    $strategyConfig = strategy_config_from_options($config, $options);
    if (($strategyConfig['external_filters']['enabled'] ?? false) === true) {
        $strategyConfig['external_indicator_snapshots'] = $repo->loadExternalIndicatorSnapshots($start, $end);
    }
    $riskConfig = risk_config_from_options($config, $options);
    $marketSymbols = symbols_from_option($options, 'market', $strategyConfig['market']['symbols'] ?? ['SPY', 'QQQ', 'SMH']);
    $benchmarkSymbol = strtoupper((string) ($options['benchmark'] ?? 'SPY'));
    $marketSymbols = array_values(array_unique(array_merge($marketSymbols, [$benchmarkSymbol])));
    $provider = provider_from_options($config, $options, $repo);

    if ($command === 'fetch') {
        $allSymbols = array_values(array_unique(array_merge($symbols, $marketSymbols)));
        $bars = $provider->getBars($allSymbols, $timeframe, $start, $end);
        $repo->saveBars($bars, $timeframe);
        foreach ($bars as $symbol => $series) {
            echo $symbol . ': saved ' . count($series) . " bars\n";
        }
        exit(0);
    }

    $barsBySymbol = $provider->getBars($symbols, $timeframe, $start, $end);
    foreach (optional_symbols_from_option($options, 'exclude-symbols') as $symbol) {
        unset($barsBySymbol[$symbol]);
    }
    $marketBars = $provider->getBars($marketSymbols, $timeframe, $start, $end);
    $indicatorCalculator = new IndicatorCalculator();
    $marketAnalyzer = new MarketRegimeAnalyzer($indicatorCalculator, $strategyConfig['market'] ?? []);
    $scanner = new PoosScanner($indicatorCalculator, $strategyConfig);

    if ($command === 'scan') {
        $regimes = $marketAnalyzer->analyze($marketBars);
        $signals = [];
        foreach ($barsBySymbol as $symbol => $series) {
            $signals = array_merge($signals, $scanner->scan($symbol, $series, $regimes));
        }
        $repo->saveSignals($signals);
        foreach (array_slice($signals, 0, 50) as $signal) {
            echo implode(' ', [
                $signal->createdAt->format('Y-m-d'),
                $signal->symbol,
                $signal->strategy,
                $signal->direction,
                'entry=' . round($signal->entry, 4),
                'stop=' . round($signal->stop, 4),
                'target=' . round($signal->target, 4),
                'score=' . round($signal->score, 2),
            ]) . "\n";
        }
        echo 'Signals: ' . count($signals) . "\n";
        exit(0);
    }

    if ($command === 'backtest') {
        $backtester = new PoosBacktester(
            $indicatorCalculator,
            $marketAnalyzer,
            $scanner,
            $strategyConfig,
            $riskConfig,
        );
        $result = $backtester->run($barsBySymbol, $marketBars);
        $repo->saveSignals($result->signals);
        $repo->saveTrades($result->trades);
        $report = (new PerformanceReport())->build($result, $marketBars[$benchmarkSymbol] ?? [], $benchmarkSymbol);
        $json = json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
        if ($json === false) {
            throw new RuntimeException('Unable to encode backtest report: ' . json_last_error_msg());
        }
        echo $json . "\n";
        exit(0);
    }

    throw new RuntimeException('Unknown command: ' . $command);
} catch (Throwable $e) {
    fwrite(STDERR, 'ERROR: ' . $e->getMessage() . "\n");
    exit(1);
}
